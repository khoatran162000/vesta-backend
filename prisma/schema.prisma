// FILE: prisma/schema.prisma — SCHEMA HOÀN CHỈNH
// Ghi đè trực tiếp file hiện tại
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
// ═══════════════════════ ENUMS ═══════════════════════
enum Role {
  ADMIN
  TEACHER
  CONTENT_CREATOR
  STUDENT
}
enum ExamStatus {
  DRAFT
  PUBLISHED
}
enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}
enum QuestionType {
  MULTIPLE_CHOICE
  FILL_IN_BLANK
  MATCHING
  ESSAY
}
enum NotificationType {
  SYSTEM_AUTO
  TEACHER_WARNING
}
// ═══════════════════════ USER ═══════════════════════
model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  studentCode  String?  @unique
  passwordHash String
  fullName     String
  phone        String?
  address      String?
  cccd         String?
  course       String?
  studyMode    String?
  notes        String?  @db.Text
  regStatus    String?
  careStaff    String?
  midCare      String?  @db.Text
  endCare      String?  @db.Text
  testScore    String?
  startDate    DateTime?
  role         Role
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Relations
  posts               Post[]
  examAttempts        ExamAttempt[]
  notifications       Notification[]
  diariesCreated      ClassDiary[]          @relation("DiaryCreator")
  materialsCreated    Material[]            @relation("MaterialCreator")
  feedbacksReceived   Feedback[]            @relation("StudentFeedback")
  feedbacksReviewed   Feedback[]            @relation("FeedbackReviewer")
  exercisesCreated    InteractiveExercise[] @relation("ExerciseCreator")
  interactiveAttempts InteractiveAttempt[]  @relation("InteractiveAttemptStudent")
  schedulesCreated    ClassSchedule[]       @relation("ScheduleCreator")
  reportsReceived     WeeklyReport[]        @relation("StudentReport")
  reportsCreated      WeeklyReport[]        @relation("ReportCreator")
  finalReportsReceived FinalReport[]        @relation("StudentFinalReport")
  finalReportsCreated  FinalReport[]        @relation("FinalReportCreator")
  @@index([role])
  @@index([isActive])
  @@index([studentCode])
  @@map("users")
}
// ═══════════════════════ POST (Blog) ═══════════════════════
model Post {
  id           String   @id @default(uuid())
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
  title        String
  slug         String   @unique
  excerpt      String?  @db.Text
  content      String   @db.LongText
  thumbnailUrl String?
  tags         Json     @default("[]")
  status       String   @default("DRAFT")
  visibility   String   @default("PUBLIC")
  visibleTo    String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  exercises    InteractiveExercise[]
  @@index([authorId])
  @@index([status])
  @@index([slug])
  @@index([visibility])
  @@map("posts")
}
// ═══════════════════════ CATEGORY ═══════════════════════
model Category {
  id          String     @id @default(uuid())
  name        String
  description String?    @db.Text
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  exams       Exam[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  @@index([parentId])
  @@map("categories")
}
// ═══════════════════════ EXAM ═══════════════════════
model Exam {
  id          String     @id @default(uuid())
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  title       String
  description String?    @db.Text
  duration    Int
  totalScore  Float
  status      ExamStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  questions    Question[]
  examAttempts ExamAttempt[]
  @@index([categoryId])
  @@index([status])
  @@map("exams")
}
// ═══════════════════════ QUESTION ═══════════════════════
model Question {
  id            String       @id @default(uuid())
  examId        String
  exam          Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  type          QuestionType
  content       String       @db.Text
  mediaUrl      String?
  options       Json?
  correctAnswer Json
  explanation   String?      @db.Text
  orderIndex    Int          @default(0)
  score         Float        @default(1)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  @@index([examId])
  @@index([type])
  @@map("questions")
}
// ═══════════════════════ EXAM ATTEMPT ═══════════════════════
model ExamAttempt {
  id           String        @id @default(uuid())
  studentId    String
  student      User          @relation(fields: [studentId], references: [id])
  examId       String
  exam         Exam          @relation(fields: [examId], references: [id])
  startTime    DateTime      @default(now())
  endTime      DateTime?
  status       AttemptStatus @default(IN_PROGRESS)
  answers      Json?
  studentNotes Json?
  score        Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  @@index([studentId])
  @@index([examId])
  @@index([status])
  @@index([studentId, examId])
  @@map("exam_attempts")
}
// ═══════════════════════ NOTIFICATION ═══════════════════════
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  type      NotificationType
  createdAt DateTime         @default(now())
  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}
// ═══════════════════════ CLASS DIARY ═══════════════════════
model ClassDiary {
  id          String   @id @default(uuid())
  course      String
  session     Int
  date        DateTime
  topic       String   @db.Text
  homework    String?  @db.Text
  duration    String?
  teacherNote String?  @db.Text
  createdBy   String
  creator     User     @relation("DiaryCreator", fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([course])
  @@index([date])
  @@map("class_diaries")
}
// ═══════════════════════ MATERIAL ═══════════════════════
model Material {
  id          String   @id @default(uuid())
  course      String
  title       String
  description String?  @db.Text
  fileUrl     String
  fileType    String?
  orderIndex  Int      @default(0)
  isPublished Boolean  @default(true)
  createdBy   String
  creator     User     @relation("MaterialCreator", fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([course])
  @@map("materials")
}
// ═══════════════════════ FEEDBACK ═══════════════════════
model Feedback {
  id             String    @id @default(uuid())
  studentId      String
  student        User      @relation("StudentFeedback", fields: [studentId], references: [id])
  title          String
  studentWork    String?   @db.LongText
  studentFileUrl String?
  teacherComment String?   @db.Text
  score          Float?
  maxScore       Float?    @default(10)
  status         String    @default("PENDING")
  reviewedBy     String?
  reviewer       User?     @relation("FeedbackReviewer", fields: [reviewedBy], references: [id])
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  @@index([studentId])
  @@index([status])
  @@map("feedbacks")
}
// ═══════════════════════ INTERACTIVE EXERCISE ═══════════════════════
model InteractiveExercise {
  id          String   @id @default(uuid())
  postId      String?
  post        Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  title       String
  description String?  @db.Text
  type        String
  questions   Json
  content     String?  @db.LongText
  gaps        Json?
  distractors Json?
  visibility  String   @default("PUBLIC")
  visibleTo   String?  @db.Text
  isPublished Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdBy   String
  creator     User     @relation("ExerciseCreator", fields: [createdBy], references: [id])
  attempts    InteractiveAttempt[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([postId])
  @@index([visibility])
  @@map("interactive_exercises")
}
// ═══════════════════════ INTERACTIVE ATTEMPT ═══════════════════════
model InteractiveAttempt {
  id          String   @id @default(uuid())
  exerciseId  String
  exercise    InteractiveExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  studentId   String?
  student     User?    @relation("InteractiveAttemptStudent", fields: [studentId], references: [id])
  answers     Json
  score       Float?
  totalScore  Float?
  detail      Json?
  createdAt   DateTime @default(now())
  @@index([exerciseId])
  @@index([studentId])
  @@map("interactive_attempts")
}
// ═══════════════════════ CLASS SCHEDULE ═══════════════════════
model ClassSchedule {
  id              String   @id @default(uuid())
  course          String
  className       String
  startDate       DateTime
  endDate         DateTime
  schedule        String
  room            String?
  teacher         String?
  maxStudents     Int      @default(15)
  currentStudents Int      @default(0)
  status          String   @default("UPCOMING")
  notes           String?  @db.Text
  createdBy       String
  creator         User     @relation("ScheduleCreator", fields: [createdBy], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([course])
  @@index([startDate])
  @@index([status])
  @@map("class_schedules")
}
// ═══════════════════════ WEEKLY REPORT (định kỳ) ═══════════════════════
model WeeklyReport {
  id             String    @id @default(uuid())
  studentId      String
  student        User      @relation("StudentReport", fields: [studentId], references: [id], onDelete: Cascade)
  course         String?
  learnclickUser String?
  padletAccount  String?
  periodTo       DateTime?
  dataFrom       DateTime?
  dataTo         DateTime?
  grid           Json?                             // nới optional: report HTML không có grid
  teacherNote    Json?
  html           String?   @db.LongText            // NEW: report HTML/CSS dán trực tiếp
  shareToken     String?   @unique                 // NEW: token link chia sẻ công khai
  status         String    @default("DRAFT")
  createdBy      String
  creator        User      @relation("ReportCreator", fields: [createdBy], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  @@index([studentId])
  @@index([status])
  @@map("weekly_reports")
}
// ═══════════════════════ FINAL REPORT (cuối khóa) ═══════════════════════
model FinalReport {
  id             String    @id @default(uuid())
  studentId      String
  student        User      @relation("StudentFinalReport", fields: [studentId], references: [id], onDelete: Cascade)
  course         String?
  learnclickUser String?
  skillGrid      Json?                              // bảng tích lũy kĩ năng (null nếu report dạng HTML)
  review         Json?
  prediction     Json?
  orientation    Json?
  html           String?   @db.LongText             // NEW: report HTML/CSS dán trực tiếp (thay Netlify)
  shareToken     String?   @unique                  // NEW: token link chia sẻ công khai cho phụ huynh
  status         String    @default("DRAFT")
  createdBy      String
  creator        User      @relation("FinalReportCreator", fields: [createdBy], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  @@index([studentId])
  @@index([status])
  @@map("final_reports")
}
// ═══════════════════════ TEACHER (Landing) ═══════════════════════
model Teacher {
  id          String   @id @default(uuid())
  name        String
  ma          String?
  subtitle    String   @db.Text
  photoUrl    String?
  badges      Json
  credentials Json
  orderIndex  Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([isPublished])
  @@map("teachers")
}
// ═══════════════════════ COURSE (Landing) ═══════════════════════
model Course {
  id            String   @id @default(uuid())
  cardType      String   @default("FULL")
  title         String
  badge         String?
  isSpecial     Boolean  @default(false)
  badgeOutline  Boolean  @default(false)
  features      Json
  commitment    String?  @db.Text
  scheduleLabel String?
  schedule      String?  @db.Text
  price         String?
  onlinePrice   String?
  cta           String?
  specialPrice  String?
  originalPrice String?
  orderIndex    Int      @default(0)
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([cardType])
  @@index([isPublished])
  @@map("courses")
}
// ═══════════════════════ BOOK (Landing) ═══════════════════════
model Book {
  id          String   @id @default(uuid())
  title       String
  price       String
  highlight   Boolean  @default(false)
  orderIndex  Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([isPublished])
  @@map("books")
}
// ═══════════════════════ SITE CONTENT (khối tĩnh landing) ═══════════════════════
model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique
  label     String
  data      Json
  updatedAt DateTime @updatedAt
  @@map("site_contents")
}